{
  "id": "health-cards",
  "contexts": ["household", "shared_space"],
  "name": "Health Cards",
  "version": "1.0.0",
  "description": "Allergy and emergency health information for every family member. Generate a printable card to share with parents, caregivers, or schools.",
  "entrypoint": "index.html",
  "runtime": "static",
  "icon": "\ud83c\udfe5",
  "category": "general",
  "tags": [
    "health",
    "allergies",
    "emergency",
    "medical",
    "kids"
  ],
  "storage": "db",
  "data_access": {
    "reads": [
      "family.members"
    ],
    "writes": []
  },
  "permissions": {
    "default_audience": "adults",
    "requires_approval": false
  },
  "row_policies": {
    "health_profiles": {
      "kind": "adult_only",
      "audit_writes": true
    },
    "health_allergies": {
      "kind": "adult_only",
      "audit_writes": true
    },
    "health_medications": {
      "kind": "adult_only",
      "audit_writes": true
    },
    "health_contacts": {
      "kind": "adult_only",
      "audit_writes": true
    }
  },
  "nav": {
    "label": "Health Cards"
  },
  "resource_limits": {
    "max_db_bytes": 52428800
  }
}
